<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sam Hill Signature Trail — Trail Design & Construction</title>
    <meta name="description" content="World-class mountain bike trail design and construction by Sam Hill. 5x World Champion bringing 20+ years of elite racing experience to trail building.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        /* ===== RESET & BASE ===== */
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; scrollbar-width: thin; scrollbar-color: #c8ff00 #111111; }
        body {
            font-family: 'Outfit', sans-serif;
            background: #0a0a0a;
            color: #f5f5f0;
            overflow-x: hidden;
            cursor: none;
        }
        ::selection { background: #c8ff00; color: #0a0a0a; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #111111; }
        ::-webkit-scrollbar-thumb { background: #c8ff00; border-radius: 3px; }
        img { max-width: 100%; display: block; }
        a { color: inherit; text-decoration: none; }
        ul { list-style: none; }
        button { border: none; background: none; cursor: none; font-family: inherit; }
        input, textarea, select { font-family: inherit; }

        /* ===== CUSTOM CURSOR ===== */
        .cursor-dot {
            width: 8px; height: 8px;
            background: #c8ff00;
            border-radius: 50%;
            position: fixed;
            top: 0; left: 0;
            pointer-events: none;
            z-index: 10001;
            transition: transform 0.1s ease;
        }
        .cursor-ring {
            width: 40px; height: 40px;
            border: 1.5px solid rgba(200, 255, 0, 0.5);
            border-radius: 50%;
            position: fixed;
            top: 0; left: 0;
            pointer-events: none;
            z-index: 10000;
            transition: width 0.3s ease, height 0.3s ease, border-color 0.3s ease;
        }
        .cursor-hover .cursor-ring {
            width: 60px; height: 60px;
            border-color: rgba(200, 255, 0, 0.8);
        }
        .cursor-hover .cursor-dot {
            transform: scale(2);
        }

        /* ===== LOADING SCREEN ===== */
        .loader {
            position: fixed;
            inset: 0;
            background: #0a0a0a;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 0.6s ease, visibility 0.6s ease;
        }
        .loader.hidden {
            opacity: 0;
            visibility: hidden;
        }
        .loader-text {
            font-family: 'Bebas Neue', sans-serif;
            font-size: clamp(2rem, 6vw, 4.5rem);
            letter-spacing: 0.3em;
            display: flex;
            gap: 2px;
            margin-bottom: 2rem;
        }
        .loader-text span {
            display: inline-block;
            opacity: 0;
            transform: translateY(30px);
            animation: letterReveal 0.5s forwards;
        }
        @keyframes letterReveal {
            to { opacity: 1; transform: translateY(0); }
        }
        .loader-bar {
            width: 200px; height: 2px;
            background: #222;
            border-radius: 1px;
            overflow: hidden;
        }
        .loader-bar-fill {
            height: 100%;
            background: #c8ff00;
            width: 0%;
            animation: loadBar 2s ease-in-out forwards;
        }
        @keyframes loadBar {
            0% { width: 0%; }
            60% { width: 70%; }
            100% { width: 100%; }
        }

        /* ===== FILM GRAIN OVERLAY ===== */
        .grain {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 9998;
            opacity: 0.04;
        }

        /* ===== NAV ===== */
        .nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            padding: 1.5rem 3rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all 0.4s ease;
        }
        .nav.scrolled {
            padding: 1rem 3rem;
            background: rgba(10, 10, 10, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }
        .nav-logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .nav-logo img {
            height: 40px;
            width: auto;
        }
        .nav-logo-text {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.2rem;
            letter-spacing: 0.15em;
            color: #f5f5f0;
        }
        .nav-logo-text .accent { color: #c8ff00; }
        .nav-links {
            display: flex;
            gap: 2rem;
            align-items: center;
        }
        .nav-links a {
            font-family: 'Space Mono', monospace;
            font-size: 0.75rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #6b6b6b;
            transition: color 0.3s ease;
            position: relative;
        }
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px; left: 0;
            width: 0; height: 1px;
            background: #c8ff00;
            transition: width 0.3s ease;
        }
        .nav-links a:hover { color: #f5f5f0; }
        .nav-links a:hover::after { width: 100%; }
        .nav-cta {
            font-family: 'Space Mono', monospace;
            font-size: 0.75rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 0.6rem 1.5rem;
            background: #c8ff00;
            color: #0a0a0a;
            clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
            transition: background 0.3s ease;
            font-weight: 700;
        }
        .nav-cta:hover { background: #d4ff33; }

        /* Hamburger */
        .hamburger {
            display: none;
            flex-direction: column;
            gap: 6px;
            padding: 0.5rem;
            z-index: 1002;
        }
        .hamburger span {
            display: block;
            width: 28px; height: 2px;
            background: #f5f5f0;
            transition: all 0.3s ease;
        }
        .hamburger.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 6px); }
        .hamburger.active span:nth-child(2) { opacity: 0; }
        .hamburger.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -6px); }

        /* Mobile Nav Overlay */
        .mobile-nav {
            position: fixed;
            inset: 0;
            background: #0a0a0a;
            z-index: 1001;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 2rem;
            opacity: 0;
            visibility: hidden;
            transition: all 0.4s ease;
        }
        .mobile-nav.active { opacity: 1; visibility: visible; }
        .mobile-nav a {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.5rem;
            letter-spacing: 0.15em;
            color: #6b6b6b;
            transition: color 0.3s ease;
        }
        .mobile-nav a:hover { color: #c8ff00; }

        /* ===== HERO ===== */
        .hero {
            position: relative;
            height: 100vh;
            min-height: 600px;
            display: flex;
            align-items: flex-end;
            padding: 4rem 3rem;
            overflow: hidden;
        }
        .hero-bg {
            position: absolute;
            inset: 0;
            background: url('https://samhillsignaturetrail.com.au/wp-content/uploads/2024/09/martins_w3a7948.jpg') center center / cover no-repeat;
            transform: scale(1.1);
            transition: transform 0.1s linear;
        }
        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, #0a0a0a 0%, rgba(10,10,10,0.6) 40%, rgba(10,10,10,0.3) 100%);
        }
        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 900px;
        }
        .hero-label {
            font-family: 'Space Mono', monospace;
            font-size: 0.75rem;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: #c8ff00;
            margin-bottom: 1.5rem;
            opacity: 0;
            transform: translateY(20px);
        }
        .hero-label.revealed { opacity: 1; transform: translateY(0); transition: all 0.6s ease 0.3s; }
        .hero-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: clamp(3.5rem, 10vw, 8rem);
            line-height: 0.95;
            letter-spacing: 0.02em;
            margin-bottom: 1.5rem;
        }
        .hero-title .line {
            display: block;
            overflow: hidden;
        }
        .hero-title .line span {
            display: inline-block;
            transform: translateY(110%);
            transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .hero-title .line span.revealed { transform: translateY(0); }
        .hero-title .accent { color: #c8ff00; }
        .hero-desc {
            font-size: 1.1rem;
            color: #999;
            max-width: 500px;
            line-height: 1.7;
            margin-bottom: 2rem;
            opacity: 0;
            transform: translateY(20px);
        }
        .hero-desc.revealed { opacity: 1; transform: translateY(0); transition: all 0.6s ease 0.8s; }
        .hero-cta {
            display: inline-block;
            font-family: 'Space Mono', monospace;
            font-size: 0.8rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            padding: 1rem 2.5rem;
            background: #c8ff00;
            color: #0a0a0a;
            font-weight: 700;
            clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
            opacity: 0;
            transform: translateY(20px);
            transition: background 0.3s ease;
        }
        .hero-cta.revealed { opacity: 1; transform: translateY(0); transition: all 0.6s ease 1s, background 0.3s ease; }
        .hero-cta:hover { background: #d4ff33; }

        /* Scroll indicator */
        .scroll-indicator {
            position: absolute;
            bottom: 2rem;
            right: 3rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            z-index: 2;
        }
        .scroll-indicator span {
            font-family: 'Space Mono', monospace;
            font-size: 0.6rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #6b6b6b;
            writing-mode: vertical-rl;
        }
        .scroll-line {
            width: 1px; height: 60px;
            background: #333;
            position: relative;
            overflow: hidden;
        }
        .scroll-line::after {
            content: '';
            position: absolute;
            top: -100%; left: 0;
            width: 100%; height: 100%;
            background: #c8ff00;
            animation: scrollPulse 2s ease-in-out infinite;
        }
        @keyframes scrollPulse {
            0% { top: -100%; }
            50% { top: 0%; }
            100% { top: 100%; }
        }

        /* ===== SECTION COMMON ===== */
        section { padding: 8rem 3rem; position: relative; }
        .section-label {
            font-family: 'Space Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: #c8ff00;
            margin-bottom: 1rem;
        }
        .section-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: clamp(2.5rem, 5vw, 4rem);
            letter-spacing: 0.02em;
            line-height: 1.05;
            margin-bottom: 2rem;
        }

        /* ===== SCROLL REVEAL ===== */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .reveal-left {
            opacity: 0;
            transform: translateX(-40px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }
        .reveal-left.visible {
            opacity: 1;
            transform: translateX(0);
        }
        .reveal-right {
            opacity: 0;
            transform: translateX(40px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }
        .reveal-right.visible {
            opacity: 1;
            transform: translateX(0);
        }

        /* ===== ABOUT ===== */
        .about {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            max-width: 1200px;
            margin: 0 auto;
            align-items: center;
        }
        .about-image {
            position: relative;
            overflow: hidden;
            clip-path: polygon(0 0, calc(100% - 30px) 0, 100% 30px, 100% 100%, 30px 100%, 0 calc(100% - 30px));
        }
        .about-image img {
            width: 100%;
            height: 500px;
            object-fit: cover;
            transition: transform 0.6s ease;
        }
        .about-image:hover img { transform: scale(1.05); }
        .about-image-border {
            position: absolute;
            bottom: -15px; right: -15px;
            width: 100%; height: 100%;
            border: 1px solid #c8ff00;
            clip-path: polygon(0 0, calc(100% - 30px) 0, 100% 30px, 100% 100%, 30px 100%, 0 calc(100% - 30px));
            z-index: -1;
        }
        .about-text p {
            color: #999;
            line-height: 1.8;
            margin-bottom: 1.5rem;
            font-size: 1rem;
        }
        .about-text p strong { color: #f5f5f0; font-weight: 600; }

        /* Stats */
        .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            margin-top: 2.5rem;
            padding-top: 2.5rem;
            border-top: 1px solid #222;
        }
        .stat-number {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 3rem;
            color: #c8ff00;
            line-height: 1;
        }
        .stat-label {
            font-family: 'Space Mono', monospace;
            font-size: 0.65rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #6b6b6b;
            margin-top: 0.5rem;
        }

        /* ===== MARQUEE ===== */
        .marquee {
            background: #c8ff00;
            padding: 1rem 0;
            overflow: hidden;
            white-space: nowrap;
        }
        .marquee-track {
            display: flex;
            animation: marqueeScroll 20s linear infinite;
        }
        .marquee-item {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.5rem;
            letter-spacing: 0.1em;
            color: #0a0a0a;
            padding: 0 2rem;
            flex-shrink: 0;
        }
        .marquee-item .dot {
            display: inline-block;
            width: 8px; height: 8px;
            background: #0a0a0a;
            border-radius: 50%;
            margin: 0 1.5rem;
            vertical-align: middle;
        }
        @keyframes marqueeScroll {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* ===== SERVICES ===== */
        #services { background: #111111; }
        .services-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        .service-card {
            background: #1a1a1a;
            padding: 2.5rem 2rem;
            position: relative;
            overflow: hidden;
            transition: all 0.4s ease;
            clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
        }
        .service-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(200,255,0,0.1) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.4s ease;
        }
        .service-card:hover::before { opacity: 1; }
        .service-card:hover { transform: translateY(-4px); }
        .service-number {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 4rem;
            color: #222;
            line-height: 1;
            margin-bottom: 1.5rem;
            transition: color 0.4s ease;
        }
        .service-card:hover .service-number { color: #c8ff00; }
        .service-card h3 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.5rem;
            letter-spacing: 0.05em;
            margin-bottom: 1rem;
        }
        .service-card p {
            font-size: 0.9rem;
            color: #6b6b6b;
            line-height: 1.7;
        }

        /* ===== MOUNTAIN DIVIDER ===== */
        .mountain-divider {
            width: 100%;
            height: 120px;
            position: relative;
            margin: -1px 0;
        }
        .mountain-divider svg {
            width: 100%;
            height: 100%;
            display: block;
        }

        /* ===== WORK / GALLERY ===== */
        .work-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        .work-item {
            position: relative;
            overflow: hidden;
            height: 350px;
            clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
        }
        .work-item.featured {
            grid-column: span 2;
            height: 400px;
        }
        .work-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }
        .work-item:hover img { transform: scale(1.08); }
        .work-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(10,10,10,0.9) 0%, transparent 60%);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 2rem;
            opacity: 0;
            transition: opacity 0.4s ease;
        }
        .work-item:hover .work-overlay { opacity: 1; }
        .work-overlay h3 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.5rem;
            letter-spacing: 0.05em;
            margin-bottom: 0.3rem;
        }
        .work-overlay span {
            font-family: 'Space Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #c8ff00;
        }

        /* ===== PROCESS / TIMELINE ===== */
        #process { background: #111111; }
        .process-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        .process-step {
            padding: 2rem;
            position: relative;
            border-left: 2px solid #222;
            transition: border-color 0.4s ease;
        }
        .process-step:hover { border-color: #c8ff00; }
        .process-num {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 3.5rem;
            color: #222;
            line-height: 1;
            margin-bottom: 1rem;
            transition: color 0.4s ease;
        }
        .process-step:hover .process-num { color: #c8ff00; }
        .process-step h3 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.3rem;
            letter-spacing: 0.05em;
            margin-bottom: 0.75rem;
        }
        .process-step p {
            font-size: 0.85rem;
            color: #6b6b6b;
            line-height: 1.7;
        }

        /* ===== QUOTE ===== */
        .quote-section {
            padding: 8rem 3rem;
            text-align: center;
            position: relative;
            max-width: 900px;
            margin: 0 auto;
        }
        .quote-mark {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 15rem;
            color: #1a1a1a;
            line-height: 0.5;
            position: absolute;
            top: 2rem;
            left: 50%;
            transform: translateX(-50%);
            user-select: none;
        }
        .quote-text {
            font-family: 'Outfit', sans-serif;
            font-size: clamp(1.3rem, 3vw, 2rem);
            font-weight: 300;
            line-height: 1.6;
            position: relative;
            z-index: 1;
            margin-bottom: 2rem;
        }
        .quote-text em { font-style: italic; color: #c8ff00; }
        .quote-author {
            font-family: 'Space Mono', monospace;
            font-size: 0.75rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #6b6b6b;
        }

        /* ===== TEAM / PARTNERS ===== */
        .team-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        .team-card {
            background: #111111;
            padding: 2.5rem 2rem;
            position: relative;
            border-left: 3px solid transparent;
            transition: all 0.4s ease;
        }
        .team-card:hover { border-left-color: #c8ff00; background: #161616; }
        .team-card h3 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.4rem;
            letter-spacing: 0.05em;
            margin-bottom: 0.3rem;
        }
        .team-role {
            font-family: 'Space Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #c8ff00;
            margin-bottom: 1rem;
        }
        .team-card p {
            font-size: 0.9rem;
            color: #6b6b6b;
            line-height: 1.7;
        }

        /* ===== CONTACT ===== */
        #contact { background: #111111; }
        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        .contact-info h3 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2rem;
            margin-bottom: 1.5rem;
        }
        .contact-info p {
            font-size: 1rem;
            color: #6b6b6b;
            line-height: 1.8;
            margin-bottom: 2rem;
        }
        .contact-detail {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }
        .contact-detail-icon {
            width: 40px; height: 40px;
            background: #1a1a1a;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
        }
        .contact-detail-icon svg { width: 18px; height: 18px; fill: #c8ff00; }
        .contact-detail span {
            font-size: 0.9rem;
            color: #999;
        }

        /* Form */
        .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }
        .form-group { position: relative; }
        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            background: #1a1a1a;
            border: 1px solid #222;
            color: #f5f5f0;
